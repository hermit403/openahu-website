---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/sections/Hero.astro";
import ProjectCard from "../components/common/ProjectCard.astro";
import MemberCard from "../components/common/MemberCard.astro";
import { getCollection } from "astro:content";

const allProjects = await getCollection("projects");
const allMembers = await getCollection("team");
---

<Layout title="OpenAHU - 开放、创新、协作">
  <Hero cta={{ text: "了解更多", href: "/#projects" }} />

  <section id="projects" class="py-16 px-4">
    <div
      class="container mx-auto max-w-6xl animate-fade-in opacity-0"
      style="animation-delay: 0.8s; animation-fill-mode: forwards;"
    >
      <div class="mb-8 text-center">
        <h2
          class="text-3xl md:text-5xl font-bold tracking-tight text-foreground mb-4"
        >
          开源项目
        </h2>
        <p class="text-muted-foreground text-lg">
          我们致力于构建高质量的校园服务应用
        </p>
      </div>

      <div class="flex flex-wrap justify-center gap-6">
        {
          allProjects.map((project) => (
            <div class="w-full md:w-[calc(50%-1.5rem)] lg:w-[calc(33.333%-1.5rem)] flex justify-center">
              <ProjectCard project={project} />
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section id="team" class="py-16 px-4">
    <div
      class="container mx-auto max-w-6xl animate-fade-in opacity-0"
      style="animation-delay: 1.0s; animation-fill-mode: forwards;"
    >
      <div class="mb-8 text-center">
        <h2
          class="text-3xl md:text-5xl font-bold tracking-tight text-foreground mb-4"
        >
          团队成员
        </h2>
        <p class="text-muted-foreground text-lg">一群热爱技术的开发者</p>
      </div>
      <div class="flex flex-wrap justify-center gap-6">
        {
          allMembers.map((member) => (
            <div class="w-full sm:w-[calc(50%-1.5rem)] md:w-[calc(33.333%-1.5rem)] lg:w-[calc(25%-1.5rem)] flex justify-center">
              <MemberCard member={member} />
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
