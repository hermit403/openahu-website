---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Button from "../../components/ui/Button.astro";
import { ArrowLeftIcon } from "@radix-ui/react-icons";
import {
  ahutongFallbackBodyHtml,
  ahutongFallbackProject,
} from "../../lib/projectFallback";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  const projectEntries =
    projects.length > 0 ? projects : [ahutongFallbackProject];

  return projectEntries.map((project) => ({
    params: { slug: project.data.slug || project.id },
    props: {
      project,
      fallbackBodyHtml:
        project.id === ahutongFallbackProject.id && projects.length === 0
          ? ahutongFallbackBodyHtml
          : undefined,
    },
  }));
}

const { project, fallbackBodyHtml } = Astro.props;
const { title, desc, downloadUrl, techstack, screenshots, links } = project.data;
const rendered = fallbackBodyHtml ? null : await render(project);
const Content = rendered?.Content ?? null;

const skillIconsUrl = `https://skillicons.dev/icons?i=${techstack.map((t) => t.toLowerCase().replace(/\s+/g, "")).join(",")}`;
---

<Layout title={`${title} - OpenAHU Project`}>
  <div class="container mx-auto px-4 py-16 max-w-4xl">
    <Button variant="ghost" size="sm" href="/" class="mb-8">
      <ArrowLeftIcon className="mr-2 h-4 w-4" /> 返回首页
    </Button>

    <div class="flex flex-col gap-8">
      <div class="space-y-4">
        <h1 class="text-4xl font-extrabold tracking-tight lg:text-5xl">
          {title}
        </h1>
        <p class="text-xl text-muted-foreground">{desc}</p>

        <div class="flex items-center gap-4 pt-4">
          <img
            src={skillIconsUrl}
            alt="Tech Stack"
            height="40"
            class="h-10"
            decoding="async"
          />
        </div>

        <div class="flex flex-wrap gap-3 pt-4">
          {
            downloadUrl !== undefined &&
              (downloadUrl ? (
                <Button href={downloadUrl} target="_blank" rel="noreferrer">
                  下载
                </Button>
              ) : (
                <Button disabled>暂无下载链接</Button>
              ))
          }
          {
            links.map((link) => (
              <Button
                variant={link.name === "Website" ? "default" : "outline"}
                href={link.url}
                target="_blank"
                rel="noreferrer"
              >
                {link.name}
              </Button>
            ))
          }
        </div>
      </div>

      {
        screenshots && screenshots.length > 0 && (
          <div class="grid gap-4">
            {screenshots.map((shot) => (
              <img
                src={shot}
                alt={`Screenshot of ${title}`}
                class="rounded-lg border border-border shadow-sm w-full"
                decoding="async"
                loading="lazy"
              />
            ))}
          </div>
        )
      }

      {
        fallbackBodyHtml ? (
          <div class="markdown-content max-w-none" set:html={fallbackBodyHtml} />
        ) : Content ? (
          <div class="markdown-content max-w-none">
            <Content />
          </div>
        ) : null
      }
    </div>
  </div>
</Layout>
