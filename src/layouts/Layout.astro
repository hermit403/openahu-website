---
import "../styles/global.css";
import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "@fontsource/inter/600.css";
import "@fontsource/inter/700.css";
import "@fontsource/jetbrains-mono/400.css";
import "@fontsource/jetbrains-mono/500.css";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "OpenAHU",
  description = "OpenAHU 是一个致力于推动开源和创新的组织",
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preload" as="image" href="/favicon.png" />
    <link rel="dns-prefetch" href="//skillicons.dev" />
    <link rel="preconnect" href="https://skillicons.dev" crossorigin />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline>
      const root = document.documentElement;
      const getThemePreference = () => {
        const savedTheme =
          typeof localStorage !== "undefined"
            ? localStorage.getItem("theme")
            : null;
        return savedTheme === "light" || savedTheme === "dark"
          ? savedTheme
          : "dark";
      };
      const applyTheme = (theme) => {
        const isDark = theme === "dark";
        root.classList.toggle("dark", isDark);
        root.style.colorScheme = isDark ? "dark" : "light";
        if (typeof localStorage !== "undefined") {
          localStorage.setItem("theme", theme);
        }
      };
      applyTheme(getThemePreference());

      if (typeof localStorage !== "undefined") {
        const observer = new MutationObserver(() => {
          const isDark = root.classList.contains("dark");
          root.style.colorScheme = isDark ? "dark" : "light";
          localStorage.setItem("theme", isDark ? "dark" : "light");
        });
        observer.observe(root, {
          attributes: true,
          attributeFilter: ["class"],
        });
      }

      if (!window.__themeToggleBound) {
        window.__themeToggleBound = true;
        document.addEventListener("click", (event) => {
          const target = event.target;
          if (!(target instanceof Element)) return;

          const button = target.closest("[data-theme-toggle]");
          if (!button) return;

          const toggleTheme = () => {
            applyTheme(root.classList.contains("dark") ? "light" : "dark");
          };

          if (
            !document.startViewTransition ||
            !(event instanceof MouseEvent)
          ) {
            toggleTheme();
            return;
          }

          const x = event.clientX;
          const y = event.clientY;
          const endRadius = Math.hypot(
            Math.max(x, innerWidth - x),
            Math.max(y, innerHeight - y)
          );
          const wasLight = !root.classList.contains("dark");
          const transition = document.startViewTransition(toggleTheme);

          transition.ready.then(() => {
            const clipPath = [
              `circle(0px at ${x}px ${y}px)`,
              `circle(${endRadius}px at ${x}px ${y}px)`,
            ];

            root.animate(
              {
                clipPath: wasLight ? clipPath : [...clipPath].reverse(),
              },
              {
                duration: 400,
                easing: "ease-in-out",
                pseudoElement: wasLight
                  ? "::view-transition-new(root)"
                  : "::view-transition-old(root)",
              }
            );
          });
        });
      }

      // Global mouse light (performance: rAF + CSS vars)
      if (window.matchMedia && window.matchMedia("(pointer: fine)").matches) {
        root.classList.add("has-pointer");
        let raf = 0,
          releaseRaf = 0;
        let latestX = window.innerWidth * 0.5,
          latestY = window.innerHeight * 0.2;

        const setLightOpacity = (value) => {
          root.style.setProperty("--mouse-light-opacity", value.toString());
        };

        const stopRelease = () => {
          if (releaseRaf) {
            cancelAnimationFrame(releaseRaf);
            releaseRaf = 0;
          }
        };

        const commit = () => {
          raf = 0;
          root.style.setProperty("--mouse-x", `${latestX}px`);
          root.style.setProperty("--mouse-y", `${latestY}px`);
        };

        const animateRelease = () => {
          stopRelease();
          const fromX = latestX;
          const fromY = latestY;
          const toX = window.innerWidth * 0.5;
          const toY = window.innerHeight * 0.2;
          const start = performance.now();
          const duration = 360;

          const step = (now) => {
            const progress = Math.min(1, (now - start) / duration);
            const eased = 1 - Math.pow(1 - progress, 3);
            latestX = fromX + (toX - fromX) * eased;
            latestY = fromY + (toY - fromY) * eased;
            setLightOpacity(1 - eased);
            commit();
            if (progress < 1) {
              releaseRaf = requestAnimationFrame(step);
            } else {
              releaseRaf = 0;
            }
          };

          releaseRaf = requestAnimationFrame(step);
        };

        window.addEventListener(
          "mousemove",
          (e) => {
            stopRelease();
            latestX = e.clientX;
            latestY = e.clientY;
            setLightOpacity(1);
            if (!raf) raf = requestAnimationFrame(commit);
          },
          { passive: true }
        );
        window.addEventListener("mouseleave", animateRelease);
        window.addEventListener("blur", animateRelease);
      }
    </script>
  </head>
  <body
    class="min-h-screen bg-background text-foreground font-sans antialiased flex flex-col selection:bg-black selection:text-white dark:selection:bg-white dark:selection:text-black"
  >
    <div class="global-mouse-light" aria-hidden="true"></div>
    <Header />
    <main class="flex-grow relative z-10">
      <slot />
    </main>
    <Footer />
  </body>
</html>
