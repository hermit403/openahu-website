---
import { cn } from "@/lib/utils";

interface Props {
  variant?:
    | "default"
    | "destructive"
    | "outline"
    | "secondary"
    | "ghost"
    | "link";
  size?: "default" | "sm" | "lg" | "icon";
  href?: string;
  class?: string;
  target?: string;
  rel?: string;
  [key: string]: any;
}

const {
  variant = "default",
  size = "default",
  href,
  class: className,
  ...props
} = Astro.props;

const variants = {
  default: "bg-primary-new text-primary-foreground hover:bg-primary-new/90",
  destructive:
    "bg-destructive text-destructive-foreground hover:bg-destructive/90",
  outline:
    "border border-input bg-background hover:bg-accent hover:text-accent-foreground",
  secondary: "bg-secondary text-secondary-foreground hover:bg-secondary/80",
  ghost: "hover:bg-accent hover:text-accent-foreground",
  link: "text-primary underline-offset-4 hover:underline",
};

const sizes = {
  default: "h-10 px-4 py-2",
  sm: "h-9 rounded-md px-3",
  lg: "h-11 rounded-md px-8",
  icon: "h-10 w-10",
};

const classes = cn(
  "inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 active:scale-95",
  variants[variant] || variants.default,
  sizes[size] || sizes.default,
  className
);

const Component = href ? "a" : "button";
---

<Component href={href} class={classes} {...props}>
  <slot />
</Component>
