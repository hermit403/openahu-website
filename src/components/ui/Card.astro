---
import { cn } from "@/lib/utils";

interface Props {
  hover?: boolean;
  class?: string;
}

const { hover = false, class: className } = Astro.props;
---

<div
  class={cn(
    "rounded-xl border border-border bg-card text-card-foreground shadow w-full",
    hover && "hover:shadow-lg transition-all duration-300",
    className
  )}
>
  <slot />
</div>
