---
import { MoonIcon, SunIcon } from "@radix-ui/react-icons";
---

<button
  class="w-10 h-12 inline-flex items-center justify-center rounded-md hover:bg-black/5 dark:hover:bg-white/10 transition-colors relative z-50 pointer-events-auto"
  aria-label="切换主题"
  id="theme-toggle"
>
  <SunIcon className="w-5 h-5 hidden dark:block" />
  <MoonIcon className="w-5 h-5 block dark:hidden" />
</button>

<script is:inline>
  (() => {
    function toggleTheme() {
      const element = document.documentElement;
      element.classList.toggle("dark");

      const isDark = element.classList.contains("dark");
      localStorage.setItem("theme", isDark ? "dark" : "light");
    }

    function handleToggleClick(event) {
      const button = event.target.closest("#theme-toggle");
      if (!button) return;

      // Check if View Transitions API is supported
      if (!document.startViewTransition) {
        toggleTheme();
        return;
      }

      const x = event.clientX;
      const y = event.clientY;
      const endRadius = Math.hypot(
        Math.max(x, innerWidth - x),
        Math.max(y, innerHeight - y)
      );

      // Capture state before transition
      const wasLight = !document.documentElement.classList.contains("dark");

      const transition = document.startViewTransition(() => {
        toggleTheme();
      });

      transition.ready.then(() => {
        const clipPath = [
          `circle(0px at ${x}px ${y}px)`,
          `circle(${endRadius}px at ${x}px ${y}px)`,
        ];

        // When going dark, animate the new (dark) layer growing
        // When going light, animate the old (dark) layer shrinking
        document.documentElement.animate(
          {
            clipPath: wasLight ? clipPath : [...clipPath].reverse(),
          },
          {
            duration: 400,
            easing: "ease-in-out",
            pseudoElement: wasLight
              ? "::view-transition-new(root)"
              : "::view-transition-old(root)",
          }
        );
      });
    }

    if (!window._themeToggleInitialized) {
      window._themeToggleInitialized = true;
      document.addEventListener("click", handleToggleClick);
    }
  })();
</script>
