---
import { type CollectionEntry } from "astro:content";
import { GitHubLogoIcon, GlobeIcon } from "@radix-ui/react-icons";
import LiquidContainer from "../ui/LiquidContainer";

interface Props {
  member: CollectionEntry<"team">;
}

const { member } = Astro.props;
const { name, desc, avatar, github, website } = member.data;
---

<div
  class="flex flex-col rounded-xl transition-transform duration-300 hover:-translate-y-1 w-full max-w-[16rem] mx-auto"
>
  <LiquidContainer
    client:visible
    fill
    className="w-full rounded-xl"
    radius={12}
  >
    <div
      class="flex flex-col items-center justify-center text-center w-full h-full"
    >
      <div
        class="relative mb-4 h-24 w-24 overflow-hidden rounded-full border-2 border-border/50 group-hover:border-primary/30 transition-colors"
      >
        <img
          src={avatar}
          alt={name}
          class="h-full w-full object-cover"
          loading="lazy"
        />
      </div>
      <h3 class="text-lg font-bold">{name}</h3>
      <p class="mt-2 text-sm text-muted-foreground line-clamp-2 h-10">
        {desc}
      </p>
      <div class="mt-4 flex gap-3 justify-center z-10 relative">
        {
          github && (
            <a
              href={`https://github.com/${github}`}
              target="_blank"
              class="text-muted-foreground hover:text-foreground transition-colors p-1"
            >
              <GitHubLogoIcon className="h-5 w-5" />
            </a>
          )
        }
        {
          website && (
            <a
              href={website}
              target="_blank"
              class="text-muted-foreground hover:text-foreground transition-colors p-1"
            >
              <GlobeIcon className="h-5 w-5" />
            </a>
          )
        }
      </div>
    </div>
  </LiquidContainer>
</div>
